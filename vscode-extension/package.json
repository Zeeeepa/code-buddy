{
  "name": "code-buddy-vscode",
  "displayName": "Code Buddy",
  "description": "AI-powered terminal assistant for VS Code",
  "version": "1.0.0",
  "publisher": "code-buddy",
  "repository": {"type": "git", "url": "https://github.com/phuetz/code-buddy"},
  "engines": {"vscode": "^1.85.0"},
  "categories": ["Programming Languages", "Machine Learning"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {"command": "codeBuddy.start", "title": "Start Code Buddy", "category": "Code Buddy"},
      {"command": "codeBuddy.askQuestion", "title": "Ask Code Buddy", "category": "Code Buddy"},
      {"command": "codeBuddy.explainCode", "title": "Explain Selected Code", "category": "Code Buddy"},
      {"command": "codeBuddy.refactorCode", "title": "Refactor Selected Code", "category": "Code Buddy"},
      {"command": "codeBuddy.generateTests", "title": "Generate Tests", "category": "Code Buddy"},
      {"command": "codeBuddy.fixError", "title": "Fix Error at Cursor", "category": "Code Buddy"},
      {"command": "codeBuddy.commitChanges", "title": "Generate Commit Message", "category": "Code Buddy"},
      {"command": "codeBuddy.showDiff", "title": "Show Proposed Changes", "category": "Code Buddy"},
      {"command": "codeBuddy.applyChanges", "title": "Apply Proposed Changes", "category": "Code Buddy"},
      {"command": "codeBuddy.rejectChanges", "title": "Reject Proposed Changes", "category": "Code Buddy"},
      {"command": "codeBuddy.switchModel", "title": "Switch AI Model", "category": "Code Buddy"},
      {"command": "codeBuddy.contextRefresh", "title": "Refresh Context Tree", "category": "Code Buddy", "icon": "$(refresh)"},
      {"command": "codeBuddy.contextClear", "title": "Clear Context", "category": "Code Buddy", "icon": "$(clear-all)"},
      {"command": "codeBuddy.contextRemoveFile", "title": "Remove from Context", "category": "Code Buddy", "icon": "$(close)"}
    ],
    "keybindings": [
      {"command": "codeBuddy.askQuestion", "key": "ctrl+shift+a", "mac": "cmd+shift+a"},
      {"command": "codeBuddy.explainCode", "key": "ctrl+shift+e", "mac": "cmd+shift+e", "when": "editorHasSelection"},
      {"command": "codeBuddy.applyChanges", "key": "ctrl+enter", "mac": "cmd+enter", "when": "codeBuddy.proposedDiffVisible"},
      {"command": "codeBuddy.rejectChanges", "key": "escape", "when": "codeBuddy.proposedDiffVisible"},
      {"command": "codeBuddy.switchModel", "key": "ctrl+shift+m", "mac": "cmd+shift+m"}
    ],
    "configuration": {
      "title": "Code Buddy",
      "properties": {
        "codeBuddy.apiKey": {"type": "string", "default": "", "description": "Grok API key"},
        "codeBuddy.model": {"type": "string", "default": "grok-3-latest", "description": "AI model to use"},
        "codeBuddy.autoApprove": {"type": "boolean", "default": false, "description": "Auto-approve safe operations"},
        "codeBuddy.showInStatusBar": {"type": "boolean", "default": true, "description": "Show in status bar"}
      }
    },
    "viewsContainers": {"activitybar": [{"id": "codeBuddy", "title": "Code Buddy", "icon": "images/icon.svg"}]},
    "views": {
      "codeBuddy": [
        {"id": "codeBuddy.chat", "name": "Chat", "type": "webview"},
        {"id": "codeBuddy.context", "name": "Context", "type": "tree"}
      ]
    },
    "menus": {
      "view/title": [
        {"command": "codeBuddy.contextRefresh", "when": "view == codeBuddy.context", "group": "navigation"},
        {"command": "codeBuddy.contextClear", "when": "view == codeBuddy.context", "group": "navigation"}
      ],
      "view/item/context": [
        {"command": "codeBuddy.contextRemoveFile", "when": "view == codeBuddy.context && viewItem == contextFile", "group": "inline"}
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.2",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {"openai": "^4.20.0"}
}
